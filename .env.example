# =============================================================================
# Mobius Chat - Environment Configuration
# =============================================================================
# Uses mobius-os-dev GCP project. See mobius-config/.env.example for full reference.
# =============================================================================

# -----------------------------------------------------------------------------
# CHAT HTTP (same origin for this service; mstart default port 8000)
# -----------------------------------------------------------------------------
API_BASE_URL=http://localhost:8000
MOBIUS_CHAT_URL=http://localhost:8000
# Optional: corpus “Open document” links in chat sources — use {document_id} and optional {page}
# MOBIUS_DOCUMENT_VIEWER_URL_TEMPLATE=https://your-rag-or-viewer/doc/{document_id}?page={page}
# Simpler: public origin of mobius-rag frontend (Vite default 5173). Chat builds ?tab=read&documentId=…&pageNumber=…
# MOBIUS_RAG_APP_PUBLIC_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# GCP CREDENTIALS
# -----------------------------------------------------------------------------
# GOOGLE_APPLICATION_CREDENTIALS=credentials/mobiusos-new-090a058b63d9.json

# -----------------------------------------------------------------------------
# CLOUD SQL (34.135.72.145)
# -----------------------------------------------------------------------------
CHAT_RAG_DATABASE_URL=postgresql://postgres:MobiusDev123$@34.135.72.145:5432/mobius_chat
# Days — roster on thread shows “fresh” (green) vs “stale” (grey) in credentialing / upload UI
# CHAT_ROSTER_FRESH_DAYS=14
# When Cloud SQL hits max_connections for app users, mstart cleanup/migrations use this superuser URL.
# Put it HERE (mstart loads and exports this file). Database name should be "postgres".
# Passwords containing $ are fine in .env; in the shell use single quotes: export VAR='...$...'
# CHAT_RAG_DATABASE_ADMIN_URL=postgresql://postgres:MobiusDev123$@127.0.0.1:5433/postgres
# Dev-only: terminate every session on mobius_* (not only idle) after admin connect — use with care.
# MOBIUS_DB_CLEANUP_TERMINATE_ALL_MOB=1

# -----------------------------------------------------------------------------
# PIPELINE (ReAct: Reason → Act → Observe)
# -----------------------------------------------------------------------------
# ReAct is default. Set to 0 to use legacy plan → clarify → resolve path.
MOBIUS_USE_REACT=1

# -----------------------------------------------------------------------------
# REDIS (local dev = prod-like; cloud for VPN)
# -----------------------------------------------------------------------------
# Local: brew services start redis
QUEUE_TYPE=redis
REDIS_URL=redis://localhost:6379/0
# Cloud: REDIS_URL=redis://10.40.102.67:6379/0

# Optional: asyncpg pool max connections per chat API/worker process (default 2). Lower = fewer DB slots.
# MOBIUS_PG_POOL_MAX_SIZE=2

# -----------------------------------------------------------------------------
# INTERNAL: credentialing / skills → dynamic LLM (POST /internal/skill-llm)
# -----------------------------------------------------------------------------
# Must match provider-roster-credentialing (CREDENTIALING_LLM_ROUTER_URL + same key).
# mstart sets a dev default; override in production with a strong secret.
# MOBIUS_SKILL_LLM_INTERNAL_KEY=your-secret
# Wall-clock asyncio cap for Vertex on credentialing_* / integrator_roster (default 900). LLM_TIMEOUT_SECONDS alone stays 60 for chat.
# CREDENTIALING_LLM_TIMEOUT_SECONDS=900
# Credentialing orchestrator POST /find-locations search_mode: copilot (registry only) or agentic (may web-enrich). Align with chat agentic when needed.
# ROSTER_CREDENTIALING_FIND_LOCATIONS_SEARCH_MODE=copilot

# -----------------------------------------------------------------------------
# VERTEX AI
# -----------------------------------------------------------------------------
VERTEX_PROJECT_ID=mobius-os-dev
VERTEX_PROJECT=mobius-os-dev
VERTEX_REGION=us-central1
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-2.5-flash

# -----------------------------------------------------------------------------
# VERTEX AI SEARCH — Gemini grounding (GCS-backed data store in AI Applications)
# -----------------------------------------------------------------------------
# Full Discovery Engine resource name (from Console → Data stores → your store):
#   projects/PROJECT_ID/locations/global/collections/default_collection/dataStores/DATA_STORE_ID
# Or set only the store id + location:
# VERTEX_AI_SEARCH_DATASTORE_ID=your-store-id
# VERTEX_AI_SEARCH_LOCATION=global
#
# When to attach retrieval tool: credentialing = only stages credentialing_* (default).
# general = other stages too, excluding planner/react_*/integrator/rag/JSON pipeline stages.
# VERTEX_AI_SEARCH_GROUNDING_MODE=credentialing
# VERTEX_AI_SEARCH_GROUNDING_MODE=general
# VERTEX_AI_SEARCH_GROUNDING_MODE=off

# -----------------------------------------------------------------------------
# VERTEX AI VECTOR SEARCH
# -----------------------------------------------------------------------------
VERTEX_INDEX_ENDPOINT_ID=projects/mobius-os-dev/locations/us-central1/indexEndpoints/156370344679047168
VERTEX_DEPLOYED_INDEX_ID=mobius_chat_dev_stream

# -----------------------------------------------------------------------------
# RAG RETRIEVAL (optional)
# -----------------------------------------------------------------------------
# When set, chat uses mobius-rag-api for retrieval (BM25+vector → rerank → assemble).
# Uncomment when using mstart (starts mobius-rag-api on port 8030).
# RAG_API_URL=http://localhost:8030
# RAG_PATH=mobius
# Max output tokens for corpus synthesis LLM (stage=rag via ModelRouter). Default 8192.
# CHAT_RAG_ANSWER_MAX_TOKENS=8192

# -----------------------------------------------------------------------------
# DOC ASSEMBLY & PROVIDER ROSTER – Google search fallback (corpus + HCPCS/CPT codes)
# -----------------------------------------------------------------------------
# Set when using mstart (starts mobius-skills/google-search on port 8004)
CHAT_SKILLS_GOOGLE_SEARCH_URL=http://localhost:8004/search?

# Provider roster / credentialing + reconciliation (mstart or uvicorn on provider-roster-credentialing, default 8011)
CHAT_SKILLS_PROVIDER_ROSTER_CREDENTIALING_URL=http://localhost:8011

# -----------------------------------------------------------------------------
# SKILLS – Web scraper (used by MCP server; tool agent calls via MCP)
# -----------------------------------------------------------------------------
# Uncomment when using mstart (starts mobius-skills/web-scraper on port 8002)
# CHAT_SKILLS_WEB_SCRAPER_URL=http://localhost:8002/scrape/review

# -----------------------------------------------------------------------------
# SKILLS – Healthcare (NPI, ICD-10, CMS coverage; used by MCP healthcare_query tool)
# -----------------------------------------------------------------------------
# Uncomment when using mobius-skills/healthcare (port 8007)
# CHAT_SKILLS_HEALTHCARE_URL=http://localhost:8007

# -----------------------------------------------------------------------------
# MCP – Tool agent calls skills via MCP (google_search, web_scrape_review, search_org_names, healthcare_query)
# -----------------------------------------------------------------------------
# Uncomment when using mstart (starts mobius-skills-mcp on port 8006)
# MCP_SERVER_URL=http://localhost:8006/mcp
# MCP_CONNECT_TIMEOUT=10
# MCP_READ_TIMEOUT=60   # web_scrape_review uses per-mode timeouts (45s–300s) for detailed crawls

# -----------------------------------------------------------------------------
# FL MEDICAID DAILY LOAD (reload and create credentialing report)
# -----------------------------------------------------------------------------
# When set, the daily load subprocess runs dbt after PML/PPL upload. Same values as mobius-dbt.
BQ_PROJECT=mobius-os-dev
BQ_LANDING_MEDICAID_DATASET=landing_medicaid_npi_dev
BQ_MARTS_MEDICAID_DATASET=mobius_medicaid_npi_dev
# Optional: GCS bucket for PML/PPL load (default: ${BQ_PROJECT}-fl-medicaid-npi-raw)
# GCS_MEDICAID_BUCKET=mobius-os-dev-fl-medicaid-npi-raw
# Optional: path to mobius-dbt repo if not sibling of mobius-chat
# MOBIUS_DBT_DIR=/path/to/mobius-dbt

# -----------------------------------------------------------------------------
# OPTIONAL LLM PROVIDERS (model router — roster entries auto-enable when key is set)
# -----------------------------------------------------------------------------
# Groq — https://console.groq.com/keys
# GROQ_API_KEY=
#
# Anthropic (Claude) — https://console.anthropic.com/ → API keys
# Enables: claude-sonnet-4-6, claude-haiku-4-5-20251001 (see model_registry.MODEL_ROSTER)
# ANTHROPIC_API_KEY=sk-ant-api03-...
# Verify without exposing the key:
#   cd mobius-chat && python scripts/check_llm_keys.py
#
# Together — https://api.together.ai/settings/api-keys
# TOGETHER_API_KEY=
#
# OpenAI (optional roster models)
# OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# AUTH & DEBUG
# -----------------------------------------------------------------------------
MOBIUS_OS_AUTH_URL=http://localhost:5001
JWT_SECRET=dev-jwt-secret-change-in-production
# When set, POST /chat/qc-audit/{id} requires header X-Mobius-QC-Audit-Secret (use same value in mobius-chat-qa env).
# MOBIUS_QC_AUDIT_SECRET=
# Thompson bandit: ignore PG adjudication history; all models draw from benchmark priors only.
# Forced exploration uses fewest total_calls. Circuit breakers unchanged. Remove or set 0 when done.
# MOBIUS_BANDIT_PRIORS_ONLY=1
#
# Post-run LLM adjudicator (100% by default). Set to 0 to disable background grading/QC merge.
# MOBIUS_POST_RUN_ADJUDICATE=1
# Adjudicate every completed turn (default 1). At scale set to 20 for ~1-in-20 sampling by correlation_id.
# MOBIUS_POST_RUN_ADJUDICATE_EVERY_N=1
# Run db/schema/025_adjudication_feedback.sql for QA scorecard thumbs (adjudication_feedback table).
CHAT_DEBUG_TRACE=1
CHAT_LIVE_STREAM=1

# ── mobius-db-agent (sync DB pool via MCP; structured errors; per-service access control) ──
# Caller identity — MUST match a manifest in mobius-db-agent/manifests/.
# Required for app.db_client (used by app/storage/feedback.py and onward as we migrate).
DB_AGENT_CALLER_ID=mobius-chat
# Optional — agent endpoint. Default: http://localhost:8008/mcp
# DB_AGENT_MCP_URL=http://localhost:8008/mcp
